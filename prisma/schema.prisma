datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("STUDENT") // Admin, Faculty, Student
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  student   Student?
  faculty   Faculty?
  sessions  Session[]
  accounts  Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Department {
  id      String    @id @default(cuid())
  name    String    @unique
  code    String    @unique
  faculty Faculty[]
  courses Course[]
}

model Student {
  id                String       @id @default(cuid())
  userId            String       @unique
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  rollNumber        String       @unique
  course            String
  semester          Int
  phone             String?
  address           String?
  dob               DateTime?
  guardianName      String?
  guardianPhone     String?
  totalFees         Float        @default(150000)
  paidFees          Float        @default(0)
  feeStatus         String       @default("DUE") // PAID, DUE, PARTIAL
  attendanceRecords Attendance[]
  feeRecords        FeeRecord[]
  examResults       ExamResult[]
  createdAt         DateTime     @default(now())
}

model Faculty {
  id            String      @id @default(cuid())
  userId        String      @unique
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId    String      @unique
  departmentId  String
  department    Department  @relation(fields: [departmentId], references: [id])
  designation   String
  qualification String?
  joiningDate   DateTime?
  subjects      String?     // Stored as comma-separated values since SQLite doesn't support arrays
  timetables    Timetable[]
  createdAt     DateTime    @default(now())
}

model Course {
  id           String      @id @default(cuid())
  name         String
  code         String      @unique
  description  String?
  credits      Int
  departmentId String
  department   Department  @relation(fields: [departmentId], references: [id])
  semesters    Int         @default(8)
  subjects     Subject[]
  exams        Exam[]
  timetables   Timetable[]
}

model Subject {
  id       String @id @default(cuid())
  name     String
  code     String
  courseId String
  course   Course @relation(fields: [courseId], references: [id])
  semester Int
  credits  Int    @default(4)
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id])
  date      DateTime
  course    String
  semester  Int
  status    String           @default("PRESENT") // PRESENT, ABSENT
  markedBy  String?
  createdAt DateTime         @default(now())
  @@unique([studentId, date, course])
}

model FeeRecord {
  id            String   @id @default(cuid())
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id])
  amount        Float
  type          String
  method        String   @default("Cash")
  transactionId String   @unique @default(cuid())
  paidAt        DateTime @default(now())
  createdBy     String?
}

model Exam {
  id         String       @id @default(cuid())
  name       String
  courseId   String
  course     Course       @relation(fields: [courseId], references: [id])
  date       DateTime
  totalMarks Int          @default(100)
  status     String       @default("Scheduled")
  results    ExamResult[]
  createdAt  DateTime     @default(now())
}

model ExamResult {
  id        String  @id @default(cuid())
  examId    String
  exam      Exam    @relation(fields: [examId], references: [id])
  studentId String
  student   Student @relation(fields: [studentId], references: [id])
  marks     Float
  grade     String
  published Boolean @default(false)
  @@unique([examId, studentId])
}

model Announcement {
  id             String               @id @default(cuid())
  title          String
  content        String
  targetAudience String               @default("ALL") // ALL, STUDENT, FACULTY
  priority       String               @default("MEDIUM") // HIGH, MEDIUM, LOW
  author         String
  authorId       String?
  createdAt      DateTime             @default(now())
}

model Timetable {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  facultyId String?
  faculty   Faculty? @relation(fields: [facultyId], references: [id])
  day       String
  time      String
  subject   String
  room      String
  type      String   @default("Lecture")
  semester  Int
}
